<style>
    #toolBar.toolBar {
        display: flex;
        position: fixed;
        margin: 12px;
        justify-content:end;
        margin-right: 0;
        right: 1em;
        bottom: 1em;
        max-width: 35px;

        flex-direction: column;
        gap: 8px; /* 按钮之间的垂直间距，可选 */
    }

    #toolBar.toolBar .button-item {
        width: 100%;
        height: 32px;
    }
</style>

<div id="toolBar" class="toolBar">
    <button onclick="lightDarkTheme.toggleTheme();" class="button-item">
        <i class="fa-solid fa-moon light-none"></i>
        <i class="fa-solid fa-sun dark-none"></i>
    </button>
    <button onclick="void 0" class="button-item">
        <i class="fa-solid fa-arrow-up"></i>
    </button>
</div>

